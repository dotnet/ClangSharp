<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<bindings>
  <namespace name="ClangSharp.Test">
    <struct name="WithDestructor" access="public" unsafe="true">
      <field name="data" access="public">
        <type>int*</type>
      </field>
