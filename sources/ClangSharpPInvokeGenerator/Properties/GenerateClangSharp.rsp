--additional
-m64
-std=c++17
--config
file=multi
codegen=preview
vtbls=trimmable
types=unix
--generate
com-proxies=false
empty-records=false
enum-operators=false
aggressive-inlining
callconv-member-function
cpp-attributes
disable-runtime-marshalling
file-scoped-namespaces
guid-member
macro-bindings
marker-interfaces
native-inheritance-attribute
setslastsystemerror-attribute
tests-nunit
unmanaged-constants
vtbl-index-attribute
--log
potential-typedef-remappings
--define-macro
_SILENCE_CXX17_ITERATOR_BASE_CLASS_DEPRECATION_WARNING
--file
libClangSharp/ClangSharp.h
--header-file
./Properties/GenerateClangSharp-LICENSE.txt
--method-class-name
clangsharp
--namespace
ClangSharp.Interop
--output
./sources/ClangSharp/Interop
--prefix-strip
clangsharp_
--remap
MSGuidDeclParts=@Guid
_CX_CK_Invalid=CX_CK_Invalid
--test-output
./tests/ClangSharp.UnitTests/InteropTests
--with-attribute
CX_ExprDependence=Flags
CX_TemplateArgumentDependence=Flags
CX_TypeDependence=Flags
--with-constant-folded-value
CX_AutoTypeKeyword.*
CX_CapturedRegionKind.*
CX_CharacterKind.*
CX_ConstexprSpecKind.*
CX_ConstructionKind.*
CX_DestructorType.*
CX_ElaboratedTypeKeyword.*
CX_ExceptionSpecificationType.*
CX_ExprDependence.*
CX_ExprObjectKind.*
CX_ExprValueKind.*
CX_FloatingSemantics.*
CX_IfStatementKind.*
CX_InclusionDirectiveKind.*
CX_InitializationStyle.*
CX_LambdaCaptureDefault.*
CX_LiteralOperatorKind.*
CX_ObjCMessageReceiverKind.*
CX_OverloadedOperatorKind.*
CX_PredefinedIdentKind.*
CX_StmtClass.*
CX_StringKind.*
CX_TemplateArgumentDependence.*
CX_TemplateNameKind.*
CX_TemplateSpecializationKind.*
CX_TypeDependence.*
CX_TypeTrait.*
CX_UnaryExprOrTypeTrait.*
CX_VariableCaptureKind.*
CX_VectorKind.*
