--additional
-m64
--config
file=multi
codegen=preview
vtbls=trimmable
types=unix
--generate
com-proxies=false
empty-records=false
enum-operators=false
aggressive-inlining
callconv-member-function
cpp-attributes
disable-runtime-marshalling
file-scoped-namespaces
guid-member
macro-bindings
marker-interfaces
native-inheritance-attribute
setslastsystemerror-attribute
tests-nunit
unmanaged-constants
vtbl-index-attribute
--log
potential-typedef-remappings
--exclude
CINDEX_VERSION_ENCODE
CINDEX_VERSION_STRINGIZE
CINDEX_VERSION_STRINGIZE_
--file
clang-c/BuildSystem.h
clang-c/CXCompilationDatabase.h
clang-c/CXDiagnostic.h
clang-c/CXErrorCode.h
clang-c/CXFile.h
clang-c/CXSourceLocation.h
clang-c/CXString.h
clang-c/Documentation.h
clang-c/ExternC.h
clang-c/FatalErrorHandler.h
clang-c/Index.h
clang-c/Platform.h
clang-c/Rewrite.h
--header-file
./Properties/GenerateClang-LICENSE.txt
--method-class-name
clang
--namespace
ClangSharp.Interop
--output
./sources/ClangSharp/Interop
--prefix-strip
clang_
--test-output
./tests/ClangSharp.UnitTests/InteropTests
